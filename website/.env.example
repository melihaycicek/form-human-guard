# --- Required in production (Vercel) ---

# HMAC signing secret for guard tokens. Long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
GUARD_SECRET=

# Upstash Redis (HTTP, serverless-safe). Without these the demo API falls back
# to MemoryStore, which only works in single-process `next dev` — on Vercel
# it returns 503 DEMO_STORE_UNAVAILABLE-style failures across instances.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret key for GET /api/waitlist/stats?key=... (counts only, never emails).
# Leave unset to disable the stats endpoint entirely.
ADMIN_KEY=

# --- Optional ---

# Canonical site origin for metadata/sitemap/hreflang. Falls back to the
# Vercel production URL, then http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
